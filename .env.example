# Required on Vercel (Settings → Environment Variables):
# NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# BOOKING_OWNER_EMAIL=taxiteamesslingen@yahoo.com
#
# Recommended on Vercel (enables email delivery status in Supabase):
# SUPABASE_SERVICE_ROLE_KEY
#
# For owner emails on Vercel (SMTP often blocked — use Resend):
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL=booking@taxiteamesslingen.cab

BOOKING_OWNER_EMAIL=taxiteamesslingen@yahoo.com

