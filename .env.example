# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required on Vercel for server-side form saves (add all NEXT_PUBLIC_* vars too):
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY

# Where booking alerts are delivered (comma-separated for multiple inboxes)
BOOKING_OWNER_EMAIL=taxiteamesslingen@yahoo.com

# Public site URL (used for sitemap)
NEXT_PUBLIC_SITE_URL=https://taxiteamesslingen.cab

# Namecheap Private Email SMTP (works in local Node dev)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=booking@taxiteamesslingen.cab
SMTP_FROM_EMAIL=booking@taxiteamesslingen.cab
SMTP_PASSWORD=your_mailbox_password_here

# Production on Cloudflare/Lovable cannot use SMTP (no TCP sockets).
# Use Resend HTTP API instead and verify taxiteamesslingen.cab in Resend:
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL=bookings@taxiteamesslingen.cab